{
    "name": "hongayetu/internal-ads-proxy",
    "description": "Proxy Laravel para a API v2 de anúncios da HongaYetu. Mantém o token ConnectedProject server-side, fora do bundle das apps mobile.",
    "type": "library",
    "license": "proprietary",
    "keywords": ["hongayetu", "ads", "proxy", "laravel", "internal"],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0",
        "illuminate/http": "^10.0 || ^11.0 || ^12.0",
        "illuminate/routing": "^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "HongaYetu\\InternalAdsProxy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HongaYetu\\InternalAdsProxy\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HongaYetu\\InternalAdsProxy\\AdsProxyServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
